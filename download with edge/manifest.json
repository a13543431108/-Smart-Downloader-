{
  "manifest_version": 3,
  "name": "下载器——Edge拓展包",
  "version": "1.0",
  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:9876/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon.png"
  }
}